@model BlogProject.Models.Post
@{
    ViewData["Title"] = Model.Title;
    var comments = ViewBag.Comments as IEnumerable<BlogProject.Models.Comment>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-body">
                    <h1>@Model.Title</h1>
                    <p class="text-muted">
                        Автор: <a asp-controller="User" asp-action="Details" asp-route-username="@Model.Author.UserName" style="color: @ViewBag.AuthorColor; font-weight: bold;">@Model.Author.UserName</a><br />
                        Опубликовано: <span class="utc-time" data-utc="@Model.CreatedAt.ToString("o")"></span>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <span>(отредактировано: <span class="utc-time" data-utc="@Model.UpdatedAt.Value.ToString("o")"></span>)</span>
                        }
                    </p>
                    <div class="mb-3">
                        @foreach (var pt in Model.PostTags)
                        {
                            <span class="badge bg-primary me-1">@pt.Tag.Name</span>
                        }
                    </div>
                    <div class="content">
                        @Html.Raw(Model.Content.Replace("\n", "<br />"))
                    </div>
                    <div class="mt-3">
                        @if (User.Identity.IsAuthenticated && (ViewBag.CanEdit ?? false))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
                        }
                        @if (User.Identity.IsAuthenticated && (ViewBag.CanDelete ?? false))
                        {
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Удалить</a>
                        }
                        <a asp-action="Index" class="btn btn-secondary">Назад</a>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <h4>Комментарии (@(comments?.Count() ?? 0))</h4>
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <form asp-controller="Comments" asp-action="Create" method="post">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <div class="form-group">
                                    <textarea name="content" class="form-control" rows="3" placeholder="Написать комментарий..."></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary mt-2">Отправить</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <p><a asp-controller="Account" asp-action="Login">Войдите</a>, чтобы оставить комментарий.</p>
                }

                @if (comments != null && comments.Any())
                {
                    foreach (var comment in comments)
                    {
                        var commentColor = ViewBag.CommentColors != null && ViewBag.CommentColors.ContainsKey(comment.Id) ? ViewBag.CommentColors[comment.Id] : "#6c757d";
                        <div class="card mb-2">
                            <div class="card-body">
                                <p class="card-text">@comment.Content</p>
                                <footer class="blockquote-footer">
                                    <a asp-controller="User" asp-action="Details" asp-route-username="@comment.Author.UserName" style="color: @commentColor; font-weight: bold;">@comment.Author.UserName</a>
                                    - <span class="utc-time" data-utc="@comment.CreatedAt.ToString("o")"></span>
                                </footer>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Комментариев пока нет. Будьте первым!</p>
                }
            </div>
        </div>
    </div>
</div>
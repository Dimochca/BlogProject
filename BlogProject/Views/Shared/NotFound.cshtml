@{
    ViewData["Title"] = "Страница не найдена";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="display-1 text-warning">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="display-4">404</h1>
        <h2 class="mb-4">Страница не найдена</h2>
        <p class="lead">Запрашиваемая страница не существует или была перемещена.</p>
        <p>Проверьте правильность адреса или вернитесь на главную.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-house-door me-1"></i>Вернуться на главную
        </a>
    </div>
</div>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Мой блог</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
                <div class="container">
                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-pencil-square me-2"></i>Мой блог
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                            aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Главная
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Posts" asp-action="Index">
                                    <i class="bi bi-newspaper me-1"></i>Все статьи
                                </a>
                            </li>
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person-circle me-1"></i>Профиль
                                    </a>
                                </li>
                            }
                            @{
                                var isAdmin = User.Identity.IsAuthenticated && User.IsInRole("Admin");
                                var isOwner = User.Identity.IsAuthenticated && User.IsInRole("Owner");
                                var isUserMode = Context.Session.GetString("UserMode") == "true";
                                var showAdminLinks = (isAdmin || isOwner) && !isUserMode;
                            }
                            @if (showAdminLinks)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                        <i class="bi bi-shield-lock me-1"></i>Админ-панель
                                    </a>
                                </li>
                            }
                            @if (isAdmin && isUserMode)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Admin" asp-action="SwitchToAdminMode">
                                        <i class="bi bi-arrow-return-left me-1"></i>Вернуться в админ-режим
                                    </a>
                                </li>
                            }
                        </ul>
                        <ul class="navbar-nav ms-auto">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <li class="nav-item">
                                    <span class="navbar-text me-3" style="color: @(ViewBag.UserColor ?? "#6c757d"); font-weight: bold;">
                                        <i class="bi bi-person-check me-1"></i>Привет, @User.Identity.Name!
                                    </span>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-box-arrow-right me-1"></i>Выйти
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item me-2">
                                    <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Register">
                                        <i class="bi bi-person-plus me-1"></i>Регистрация
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">
                                        <i class="bi bi-box-arrow-in-right me-1"></i>Вход
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="content">
            <div class="container py-3">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>

        <footer class="footer border-top bg-light py-3">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 text-md-start text-center">
                        <span class="text-muted">
                            &copy; @DateTime.Now.Year - Мой блог. Все права защищены.
                        </span>
                    </div>
                    <div class="col-md-6 text-md-end text-center">
                        <a href="mailto:dimae030409@gmail.com" class="text-decoration-none text-muted me-3" title="Email">
                            <i class="bi bi-envelope" style="font-size: 1.2rem;"></i>
                        </a>
                        <a href="https://t.me/dimochca42" target="_blank" class="text-decoration-none text-muted me-3" title="Telegram">
                            <i class="bi bi-telegram" style="font-size: 1.2rem;"></i>
                        </a>
                        <a href="https://github.com/Dimochca" target="_blank" class="text-decoration-none text-muted" title="GitHub">
                            <i class="bi bi-github" style="font-size: 1.2rem;"></i>
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.utc-time').forEach(function (el) {
                const utc = el.getAttribute('data-utc');
                if (utc) {
                    const date = new Date(utc);
                    el.textContent = date.toLocaleString('ru-RU', {
                        year: 'numeric',
                        month: '2-digit',
                        day: '2-digit',
                        hour: '2-digit',
                        minute: '2-digit'
                    });
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
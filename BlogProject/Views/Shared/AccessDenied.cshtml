@{
    ViewData["Title"] = "Доступ запрещён";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="display-1 text-danger">
            <i class="bi bi-shield-exclamation"></i>
        </div>
        <h1 class="display-4">403</h1>
        <h2 class="mb-4">Доступ запрещён</h2>
        <p class="lead">У вас недостаточно прав для просмотра этой страницы.</p>
        <p>Пожалуйста, свяжитесь с администратором, если считаете, что это ошибка.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-house-door me-1"></i>Вернуться на главную
        </a>
    </div>
</div>
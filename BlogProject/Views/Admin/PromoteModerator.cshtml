@{
    ViewData["Title"] = "Назначить модератора";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">Назначить модератора</h3>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="form-group mb-3">
                            <label for="userName" class="form-label">Имя пользователя</label>
                            <input type="text" name="userName" id="userName" class="form-control" placeholder="Введите имя пользователя" required />
                            <small class="form-text text-muted">Введите точное имя пользователя, которого хотите сделать модератором.</small>
                        </div>
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-info">Назначить</button>
                            <a asp-action="Index" class="btn btn-secondary">Отмена</a>
                        </div>
                    </form>
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success mt-3">@TempData["Message"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger mt-3">@TempData["Error"]</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Админ-панель";
}

<div class="container mt-4">
    <h2><i class="bi bi-shield-lock me-2"></i>Админ-панель</h2>
    <div class="list-group mt-3">
        <a asp-action="Users" class="list-group-item list-group-item-action">
            <i class="bi bi-people me-2"></i>Просмотр пользователей
        </a>

        @if (User.IsInRole("Owner"))
        {
            <a asp-controller="Roles" asp-action="Index" class="list-group-item list-group-item-action">
                <i class="bi bi-shield-plus me-2"></i>Управление ролями
            </a>
        }

        @if (User.IsInRole("Owner") || User.IsInRole("Admin"))
        {
            <a asp-controller="Tags" asp-action="Index" class="list-group-item list-group-item-action">
                <i class="bi bi-tags me-2"></i>Управление тегами
            </a>
        }

        <a asp-action="SwitchToUserMode" class="list-group-item list-group-item-action">
            <i class="bi bi-person me-2"></i>Режим обычного пользователя
        </a>
    </div>
</div>
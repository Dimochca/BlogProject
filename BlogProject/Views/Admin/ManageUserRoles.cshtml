@{
    ViewData["Title"] = "Управление ролями пользователя";
    var user = ViewBag.User as BlogProject.Models.User;
    var allRoles = ViewBag.AllRoles as IEnumerable<BlogProject.Models.Role>;
    var userRoles = ViewBag.UserRoles as IEnumerable<BlogProject.Models.Role>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5><i class="bi bi-person me-2"></i>Пользователь: @user.UserName</h5>
                </div>
                <div class="card-body">
                    <p><strong>Email:</strong> @user.Email</p>
                    <p><strong>ID:</strong> @user.Id</p>
                    <p>
                        <strong>Текущие роли:</strong>
                        @if (userRoles != null && userRoles.Any())
                        {
                            foreach (var role in userRoles)
                            {
                                <span class="badge" style="background-color: @role.Color !important; color: #fff; margin: 2px;">@role.Name</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Нет ролей</span>
                        }
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5><i class="bi bi-shield me-2"></i>Роли пользователя</h5>
                </div>
                <div class="card-body">
                    @if (userRoles != null && userRoles.Any())
                    {
                        <ul class="list-group">
                            @foreach (var role in userRoles)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span style="color: @role.Color; font-weight: bold;">@role.Name</span>
                                    <form asp-action="RemoveRole" method="post" style="display:inline;">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="roleId" value="@role.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">У пользователя нет ролей</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header bg-white">
                    <h5><i class="bi bi-plus-circle me-2"></i>Добавить роль</h5>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    @if (TempData["Message"] != null)
                    {
                        <div class="alert alert-success">@TempData["Message"]</div>
                    }
                    <form asp-action="AssignRole" method="post">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <div class="input-group">
                            <select name="roleId" class="form-select">
                                <option value="">Выберите роль...</option>
                                @foreach (var role in allRoles)
                                {
                                    if (!userRoles.Any(r => r.Id == role.Id))
                                    {
                                        <option value="@role.Id" style="color: @role.Color;">@role.Name</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-primary">Назначить</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <a asp-action="Users" class="btn btn-secondary">Назад к списку пользователей</a>
    </div>
</div>
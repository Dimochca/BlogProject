@model IEnumerable<BlogProject.Models.User>
@{
    ViewData["Title"] = "Пользователи";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-people me-2"></i>Пользователи</h2>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>

    <form method="get" asp-action="Users" class="mb-3">
        <div class="input-group">
            <input type="text" name="searchTerm" class="form-control" placeholder="Поиск по имени или email..." value="@ViewBag.SearchTerm" />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search me-1"></i>Найти
            </button>
            <a asp-action="Users" class="btn btn-outline-secondary">Сбросить</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Пользователей не найдено.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Роли</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var userRoles = user.UserRoles?.Select(ur => ur.Role).OrderByDescending(r => r.Position).ToList() ?? new List<BlogProject.Models.Role>();
                        var userColor = userRoles.FirstOrDefault()?.Color ?? "#6c757d";

                        <tr>
                            <td>@user.Id</td>
                            <td>
                                <a asp-controller="User" asp-action="Details" asp-route-username="@user.UserName"
                                   style="color: @userColor; font-weight: bold;">
                                    @user.UserName
                                </a>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (userRoles.Any())
                                {
                                    foreach (var role in userRoles)
                                    {
                                        <span class="badge" style="background-color: @role.Color !important; color: #fff; margin: 2px;">@role.Name</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Нет ролей</span>
                                }
                            </td>
                            <td>
                                <a asp-action="ManageUserRoles" asp-route-id="@user.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-shield me-1"></i>Роли
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
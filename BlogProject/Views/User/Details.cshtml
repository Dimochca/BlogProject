@model BlogProject.Models.User
@{
    ViewData["Title"] = $"Пользователь {Model.UserName}";
    var posts = ViewBag.Posts as IEnumerable<BlogProject.Models.Post>;
    var userRoles = Model.UserRoles?.Select(ur => ur.Role).OrderByDescending(r => r.Position).ToList() ?? new List<BlogProject.Models.Role>();
    var userColor = userRoles.FirstOrDefault()?.Color ?? "#6c757d";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <div class="display-1" style="color: @userColor;">
                        <i class="bi bi-person-circle"></i>
                    </div>

                    <h3 style="color: @userColor;">@Model.UserName</h3>
                    <p class="text-muted">@Model.Email</p>

                    <div>
                        @if (userRoles.Any())
                        {
                            foreach (var role in userRoles)
                            {
                                <span class="badge" style="background-color: @role.Color !important; color: #fff; padding: 5px 10px; margin: 2px;">@role.Name</span>
                            }
                        }
                        else
                        {
                            <span class="badge bg-secondary">Нет ролей</span>
                        }
                    </div>

                    <p class="small text-muted mt-2">
                        Зарегистрирован: <span class="utc-time" data-utc="@Model.CreatedAt.ToString("o")"></span>
                    </p>

                    @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == Model.Id.ToString())
                    {
                        <a asp-controller="Profile" asp-action="Edit" class="btn btn-primary">
                            <i class="bi bi-pencil me-1"></i>Редактировать профиль
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-newspaper me-1"></i>Статьи пользователя</h5>
                </div>
                <div class="card-body">
                    @if (posts != null && posts.Any())
                    {
                        <div class="list-group">
                            @foreach (var post in posts)
                            {
                                <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span>@post.Title</span>
                                    <span class="badge bg-primary rounded-pill">
                                        <span class="utc-time" data-utc="@post.CreatedAt.ToString("o")"></span>
                                    </span>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">У пользователя пока нет статей.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Главная";
    var topPosts = ViewBag.TopPosts as IEnumerable<BlogProject.Models.Post>;
}

<div class="text-center">
    <h1 class="display-4">Добро пожаловать в мой блог!</h1>
    <p class="lead">Делитесь мыслями, идеями и вдохновением.</p>

    @if (User.Identity.IsAuthenticated)
    {
        <div class="mt-4">
            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-lg">✏️ Создать новую статью</a>
            <a asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary btn-lg">📖 Читать все статьи</a>
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-success btn-lg">📝 Зарегистрироваться</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">🔑 Войти</a>
        </div>
        <p class="mt-3">
            Уже есть аккаунт? <a asp-controller="Account" asp-action="Login">Войдите</a>,
            чтобы создавать статьи и комментировать.
        </p>
    }
</div>

@if (topPosts != null && topPosts.Any())
{
    <div class="mt-5">
        <h3 class="text-center">🔥 Популярные за сутки</h3>
        <div class="row mt-3">
            @foreach (var post in topPosts)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 border-bottom pb-2">
                        <div class="card-body px-0">
                            <h5 class="card-title">@post.Title</h5>
                            <p class="card-text text-muted small">
                                Автор: <a asp-controller="User" asp-action="Details" asp-route-username="@post.Author.UserName">@post.Author.UserName</a><br />
                                <span class="utc-time" data-utc="@post.CreatedAt.ToString("o")"></span>
                            </p>
                            <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" class="btn btn-outline-primary btn-sm">Читать</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
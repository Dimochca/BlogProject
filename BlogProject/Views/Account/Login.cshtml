@model BlogProject.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Вход</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Login" class="control-label"></label>
                            <input asp-for="Login" class="form-control" placeholder="Введите email или имя пользователя" />
                            <span asp-validation-for="Login" class="text-danger"></span>
                        </div>

                        <!-- Поле Пароль с кнопкой показа -->
                        <div class="form-group mb-3 position-relative">
                            <label asp-for="Password" class="control-label"></label>
                            <input asp-for="Password" class="form-control" id="loginPassword" placeholder="Введите пароль" />
                            <span id="toggleLoginPassword" style="position: absolute; right: 10px; top: 38px; cursor: pointer; user-select: none;">👁️</span>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-success w-100">Войти</button>
                        </div>
                        <div class="text-center mt-3">
                            <a asp-action="Register">Нет аккаунта? Зарегистрируйтесь</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const toggle = document.getElementById('toggleLoginPassword');
            const input = document.getElementById('loginPassword');
            toggle.addEventListener('click', function () {
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                this.textContent = type === 'password' ? '👁️' : '👁️‍🗨️';
            });
        });
    </script>
}
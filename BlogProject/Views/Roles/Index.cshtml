@model IEnumerable<BlogProject.Models.Role>
@{
    ViewData["Title"] = "Управление ролями";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-shield-plus me-2"></i>Роли</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Создать роль
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">Ролей пока нет.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Цвет</th>
                        <th>Приоритет</th>
                        <th>Права</th>
                        <th>Системная</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td style="color: @role.Color; font-weight: bold;">@role.Name</td>
                            <td>
                                <span style="display: inline-block; width: 20px; height: 20px; background-color: @role.Color; border-radius: 4px;"></span>
                            </td>
                            <td>@role.Position</td>
                            <td>
                                @if (role.RolePermissions != null && role.RolePermissions.Any())
                                {
                                    @string.Join(", ", role.RolePermissions.Select(rp => rp.Permission.Name))
                                }
                                else
                                {
                                    <span class="text-muted">Нет прав</span>
                                }
                            </td>
                            <td>@(role.IsSystem ? "Да" : "Нет")</td>
                            <td>
                                @if (!role.IsSystem)
                                {
                                    <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Системная</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    <div class="mt-3">
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
</div>
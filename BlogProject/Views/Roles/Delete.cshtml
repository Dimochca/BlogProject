@model BlogProject.Models.Role
@{
    ViewData["Title"] = "Удаление роли";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h4><i class="bi bi-exclamation-triangle me-2"></i>Удаление роли</h4>
                </div>
                <div class="card-body">
                    <p class="lead">Вы уверены, что хотите удалить роль <strong>@Model.Name</strong>?</p>
                    <p>Это действие необратимо. Все пользователи, у которых есть эта роль, потеряют её.</p>

                    @if (Model.IsSystem)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Это системная роль, её нельзя удалить.
                        </div>
                    }

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger" @(Model.IsSystem ? "disabled" : "")>
                            Подтвердить удаление
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
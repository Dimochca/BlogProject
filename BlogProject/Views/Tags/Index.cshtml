@model IEnumerable<BlogProject.Models.Tag>
@{
    ViewData["Title"] = "Управление тегами";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Теги</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Создать тег</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Тегов пока нет. Создайте первый!</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tag in Model)
                {
                    <tr>
                        <td>@tag.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@tag.Id" class="btn btn-warning btn-sm">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@tag.Id" class="btn btn-danger btn-sm">Удалить</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    <div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">На главную</a>
    </div>
</div>
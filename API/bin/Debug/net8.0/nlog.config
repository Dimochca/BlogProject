<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="logs/internal-nlog.txt">

	<targets>
		<target name="fileUserActions" xsi:type="File"
                fileName="logs/actions-${shortdate}.log"
                layout="${longdate} | ${level:uppercase=true} | User: ${aspnet-user-identity} | Action: ${message} | ${callsite} | ${exception:format=toString}"
                archiveEvery="Day"
                maxArchiveFiles="30" />

		<target name="fileErrors" xsi:type="File"
                fileName="logs/errors-${shortdate}.log"
                layout="${longdate} | ${level:uppercase=true} | User: ${aspnet-user-identity} | ${message} | ${callsite} | ${exception:format=toString,StackTrace}"
                archiveEvery="Day"
                maxArchiveFiles="30" />

		<target name="console" xsi:type="Console"
                layout="${longdate} | ${level:uppercase=true} | ${message}" />
	</targets>

	<rules>
		<logger name="*" minlevel="Info" writeTo="fileUserActions,console" />

		<logger name="*" minlevel="Error" writeTo="fileErrors" />
	</rules>
</nlog>